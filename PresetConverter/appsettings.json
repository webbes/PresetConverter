{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "PresetConverter": {
    "Inputs": [],
    "OutputDirectory": null,
    "OnExisting": "Skip",
    "ForceOutputDirectory": true
  },
  "Prusa": {
    "ConfigurationDirectory": "%APPDATA%\\PrusaSlicer",
    "InputPatterns": [
      "filament\\*.ini",
      "vendor\\*.ini"
    ],
    "SkipIncompletePresets": true,
    "PresetIdPattern": "^[^@]+$"
  },
  "Orca": {
    "PrinterSpecificGCode": "RemoveBrandBlocks",
    "NozzleSize": null,
    "OrcaSlicerVersion": "1.6.0.0"
  }
}
